{
  "name": "tmp-smoke",
  "version": "1.0.0",
  "scripts": {
    "pr:review": "git diff origin/main...HEAD | pr-review-orchestrator review --stdin --format github-pr",
    "pr:review:dry": "git diff origin/main...HEAD | pr-review-orchestrator review --stdin --dry-run",
    "pr:review:init": "pr-review-orchestrator init"
  },
  "devDependencies": {
    "pr-review-orchestrator": "latest"
  }
}
